{
  "name": "@hanzo/insights-webpack-plugin",
  "version": "1.2.25",
  "description": "Webpack plugin for Hanzo Insights source map upload.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hanzoai/insights-js.git",
    "directory": "packages/webpack-plugin"
  },
  "author": {
    "name": "Hanzo AI",
    "email": "dev@hanzo.ai",
    "url": "https://hanzo.ai"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@hanzo/insights-core": "workspace:*"
  },
  "files": [
    "dist",
    "src"
  ],
  "peerDependencies": {
    "webpack": "^5"
  },
  "devDependencies": {
    "@hanzo/insights-tooling-tsconfig-base": "workspace:*",
    "@rslib/core": "catalog:",
    "jest": "catalog:",
    "webpack": "^5"
  },
  "scripts": {
    "clean": "rimraf dist",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "build": "rslib build",
    "test:unit": "jest --passWithNoTests",
    "dev": "rslib build --watch",
    "package": "pnpm pack --out $PACKAGE_DEST/%s.tgz"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  }
}
