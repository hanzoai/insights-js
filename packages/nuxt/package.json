{
  "name": "@hanzo/insights-nuxt",
  "version": "1.5.72",
  "description": "Nuxt module for Hanzo Insights.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hanzoai/insights-js.git",
    "directory": "packages/nuxt"
  },
  "license": "MIT",
  "engines": {
    "node": "^20.20.0 || >=22.22.0"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "nuxt prepare",
    "build": "nuxt-module-build build",
    "package": "pnpm pack --out $PACKAGE_DEST/%s.tgz",
    "lint": "eslint ."
  },
  "dependencies": {
    "@hanzo/cli": "catalog:",
    "@nuxt/kit": ">=3.7.0",
    "@hanzo/insights-node": "workspace:*",
    "@hanzo/insights-core": "workspace:*",
    "@hanzo/insights": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "nuxt": "^4.1.2",
    "@nuxt/devtools": "^2.6.5",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.1.2",
    "@nuxt/eslint-config": "^1.9.0",
    "eslint": "^9.37.0"
  }
}
