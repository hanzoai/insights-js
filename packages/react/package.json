{
  "name": "@hanzo/insights-react",
  "version": "1.9.0",
  "description": "React components and hooks for Hanzo Insights.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hanzoai/insights-js.git",
    "directory": "packages/react"
  },
  "author": {
    "name": "Hanzo AI",
    "email": "dev@hanzo.ai",
