{
  "name": "@hanzo/insights-rollup-plugin",
  "version": "1.2.14",
  "description": "Rollup plugin for Hanzo Insights source map upload.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hanzoai/insights-js.git",
    "directory": "packages/rollup-plugin"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "rslib build",
    "clean": "rimraf dist",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test:unit": "jest --passWithNoTests",
    "dev": "rslib build --watch",
    "package": "pnpm pack --out $PACKAGE_DEST/%s.tgz"
  },
  "files": [
    "src",
    "dist"
  ],
  "dependencies": {
    "@hanzo/insights-core": "workspace:*"
  },
  "peerDependencies": {
    "rollup": ">= 4.0.0"
  },
  "devDependencies": {
    "@hanzo/insights-tooling-tsconfig-base": "workspace:*",
    "@rslib/core": "catalog:",
    "@types/jest": "catalog:",
    "jest": "catalog:",
    "rollup": "~4.53.2"
  }
}
