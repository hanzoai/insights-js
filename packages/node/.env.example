# Insights Node.js SDK Example Configuration
# Copy this file to .env and fill in your values

# Your Insights project API key (required)
# Find this in Insights: Settings > Project > Project API Key
INSIGHTS_PROJECT_API_KEY=phc_your_project_api_key

# Your Insights personal API key (optional, required for local evaluation)
# Find this in Insights: Settings > Personal API Keys
# Keys are prefixed with "phx_"
INSIGHTS_PERSONAL_API_KEY=phx_your_personal_api_key

# Insights host (optional, defaults to http://localhost:8000)
# For Insights Cloud US: https://us.i.insights.hanzo.ai
# For Insights Cloud EU: https://eu.i.insights.hanzo.ai
# INSIGHTS_HOST=https://us.i.insights.hanzo.ai
