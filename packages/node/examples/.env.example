# Insights ETag Polling Test Configuration
# Copy this file to .env and fill in your values

# Your Insights project API key (required)
INSIGHTS_PROJECT_API_KEY=phc_your_project_api_key

# Your Insights personal API key for local evaluation (required)
INSIGHTS_PERSONAL_API_KEY=phx_your_personal_api_key

# Insights host (optional, defaults to https://us.i.insights.hanzo.ai)
# INSIGHTS_HOST=https://us.i.insights.hanzo.ai
